<section
  class="hero-banner"
  style="background: linear-gradient(135deg, {{ section.settings.gradient_start }}, {{ section.settings.gradient_end }});"
>
  <!-- Particles Container (Snow / Stars) -->
  {% if section.settings.enable_particles %}
  <div class="particles-container" aria-hidden="true">
    {% for i in (1..30) %}
      <div class="particle particle-{{ i }}"></div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="hero-banner__content">
    {% if section.settings.heading %}
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.subheading %}
      <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.settings.cta_text and section.settings.cta_link %}
      <a href="{{ section.settings.cta_link }}" class="btn btn-primary btn-hero">
        {{ section.settings.cta_text }}
        <span class="btn-arrow">&rarr;</span>
      </a>
    {% endif %}
  </div>

  <!-- Decorative bottom wave -->
  <div class="hero-banner__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 60C240 120 480 0 720 60C960 120 1200 0 1440 60V120H0V60Z" fill="#FAF7F2"/>
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gifts That Tell a Story"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Handpicked Creative Gifts for Every Special Moment"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Shop Holiday Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    },
    {
      "type": "checkbox",
      "id": "enable_particles",
      "label": "Enable snowfall / star particles",
      "default": true
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Gradient start color",
      "default": "#8B1A2B"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "Gradient end color",
      "default": "#2D2D2D"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
