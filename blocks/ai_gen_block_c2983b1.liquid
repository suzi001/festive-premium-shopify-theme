{% doc %}
  @prompt
    product
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-card-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-product-card__image-wrapper-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-card__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ai-product-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-product-card__vendor-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.vendor_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .ai-product-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-product-card__title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-card__title-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-product-card__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .ai-product-card__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
  }

  .ai-product-card__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | times: 0.85 | round }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-product-card__description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .ai-product-card__button-{{ ai_gen_id }} {
    display: inline-block;
    width: 100%;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-align: center;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-product-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-product-card__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-product-card-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-product-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-card__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.product %}
      {% if block.settings.product.featured_image %}
        <img
          src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
          alt="{{ block.settings.product.featured_image.alt | escape }}"
          loading="lazy"
          width="800"
          height="800"
        >
      {% else %}
        <div class="ai-product-card__image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if block.settings.show_badge and block.settings.product.compare_at_price > block.settings.product.price %}
        <div class="ai-product-card__badge-{{ ai_gen_id }}">
          Sale
        </div>
      {% endif %}
    {% else %}
      <div class="ai-product-card__image-placeholder-{{ ai_gen_id }}">
        {{ 'product-1' | placeholder_svg_tag }}
        <div class="ai-product-card__empty-state-{{ ai_gen_id }}">
          Next, select a product
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-product-card__content-{{ ai_gen_id }}">
    {% if block.settings.product %}
      {% if block.settings.show_vendor and block.settings.product.vendor != blank %}
        <div class="ai-product-card__vendor-{{ ai_gen_id }}">
          {{ block.settings.product.vendor }}
        </div>
      {% endif %}

      <h3 class="ai-product-card__title-{{ ai_gen_id }}">
        <a href="{{ block.settings.product.url }}" class="ai-product-card__title-link-{{ ai_gen_id }}">
          {{ block.settings.product.title }}
        </a>
      </h3>

      {% if block.settings.show_price %}
        <div class="ai-product-card__price-wrapper-{{ ai_gen_id }}">
          <span class="ai-product-card__price-{{ ai_gen_id }}">
            {{ block.settings.product.price | money }}
          </span>
          {% if block.settings.product.compare_at_price > block.settings.product.price %}
            <span class="ai-product-card__compare-price-{{ ai_gen_id }}">
              {{ block.settings.product.compare_at_price | money }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_description and block.settings.product.description != blank %}
        <div class="ai-product-card__description-{{ ai_gen_id }}">
          {{ block.settings.product.description | strip_html | truncate: 120 }}
        </div>
      {% endif %}

      <a href="{{ block.settings.product.url }}" class="ai-product-card__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% else %}
      <h3 class="ai-product-card__title-{{ ai_gen_id }}">Product title</h3>
      <div class="ai-product-card__price-wrapper-{{ ai_gen_id }}">
        <span class="ai-product-card__price-{{ ai_gen_id }}">¥99.00</span>
      </div>
      <a href="#" class="ai-product-card__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Product card",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View product"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "vendor_color",
      "label": "Vendor",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "compare_price_color",
      "label": "Compare price",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Badge background",
      "default": "#ff0000"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 12,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Product card"
    }
  ]
}
{% endschema %}