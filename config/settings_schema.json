[
  {
    "name": "theme_info",
    "theme_name": "Festive Premium",
    "theme_version": "1.0.0",
    "theme_author": "WonderNest",
    "theme_documentation_url": "",
    "theme_support_url": ""
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Primary Colors"
      },
      {
        "type": "color",
        "id": "color_wine",
        "label": "Deep Wine (Primary accent)",
        "default": "#8B1A2B"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Dark Gold (Secondary accent)",
        "default": "#C9A96E"
      },
      {
        "type": "color",
        "id": "color_cream",
        "label": "Cream White (Background)",
        "default": "#FAF7F2"
      },
      {
        "type": "color",
        "id": "color_dark",
        "label": "Dark Gray (Text)",
        "default": "#2D2D2D"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Fonts"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "playfair_display_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4"
      }
    ]
  },
  {
    "name": "Holiday Mode",
    "settings": [
      {
        "type": "header",
        "content": "Seasonal Settings"
      },
      {
        "type": "checkbox",
        "id": "holiday_mode",
        "label": "Enable holiday mode",
        "default": true,
        "info": "Enables snowfall particles, holiday countdown, and festive accent colors."
      },
      {
        "type": "text",
        "id": "countdown_target_date",
        "label": "Countdown target date (YYYY-MM-DD)",
        "default": "2026-12-25",
        "info": "Used by the Holiday Countdown section. Change this for Valentine's Day (2027-02-14), etc."
      },
      {
        "type": "checkbox",
        "id": "show_snowfall",
        "label": "Show snowfall / star particles",
        "default": true,
        "info": "Displays animated particles on the hero banner."
      }
    ]
  },
  {
    "name": "Announcement Bar",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_announcement",
        "label": "Show announcement bar",
        "default": true
      },
      {
        "type": "richtext",
        "id": "announcement_text",
        "label": "Announcement text",
        "default": "<p>Free Shipping on Orders Over $50 | Holiday Special</p>"
      },
      {
        "type": "color",
        "id": "announcement_bg",
        "label": "Background color",
        "default": "#8B1A2B"
      },
      {
        "type": "color",
        "id": "announcement_text_color",
        "label": "Text color",
        "default": "#FAF7F2"
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width (px)",
        "min": 50,
        "max": 300,
        "step": 10,
        "default": 180
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social Links"
      },
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_email",
        "label": "Contact email",
        "default": "hello@wondernest.com"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Upload a 32 x 32 px PNG image."
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "header",
        "content": "Cart Settings"
      },
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      }
    ]
  }
]
